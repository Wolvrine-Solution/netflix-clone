{
  "name": "@netflix/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "build": "expo export",
    "build:web": "expo export --platform web",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "record:features": "./record-feature-videos.sh",
    "record:features:headed": "./record-feature-videos.sh headed"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.1.1",
    "@netflix/types": "workspace:*",
    "clsx": "^2.1.1",
    "expo-linear-gradient": "~57.0.1",
    "@react-native-async-storage/async-storage": "3.1.1",
    "@tanstack/react-query": "^5.101.4",
    "axios": "^1.18.1",
    "expo": "~57.0.8",
    "expo-image": "~57.0.1",
    "expo-router": "~57.0.8",
    "expo-screen-orientation": "~57.0.1",
    "expo-secure-store": "~57.0.1",
    "expo-status-bar": "~57.0.1",
    "expo-video": "~57.0.2",
    "nativewind": "^4.1.23",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "react-native": "0.86.0",
    "react-native-web": "~0.21.2",
    "@expo/metro-runtime": "~57.0.7",
    "react-native-gesture-handler": "~3.1.0",
    "react-native-reanimated": "~4.5.3",
    "react-native-worklets": "0.11.2",
    "react-native-safe-area-context": "5.8.0",
    "react-native-screens": "~4.26.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "8.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.17",
    "jest": "^30.4.2",
    "jest-expo": "~57.0.2",
    "tailwindcss": "^4.3.3",
    "typescript": "^7.0.2",
    "eslint": "^10.7.0",
    "eslint-config-expo": "~57.0.0",
    "globals": "^17.7.0"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "./jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(\\.pnpm/[^/]+/node_modules/)?((jest-)?react-native|@react-native(-community)?|expo([a-z-]+)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|nativewind|react-native-css-interop)/)"
    ],
    "moduleNameMapper": {
      "^@netflix/types$": "<rootDir>/../../packages/types/src/index.ts"
    }
  }
}
