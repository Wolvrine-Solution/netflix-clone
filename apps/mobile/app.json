{
  "expo": {
    "name": "Netflix Clone",
    "slug": "netflix-clone-mobile",
    "version": "1.0.0",
    "scheme": "netflixclone",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0A0B",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0B"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.netflixclone.mobile"
    },
    "android": {
      "package": "com.netflixclone.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0B"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
