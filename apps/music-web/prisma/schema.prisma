generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ProcessingJob {
  id          String   @id @default(cuid())
  status      String   @default("queued")
  progress    Int      @default(0)
  sourceUrl   String?
  fileKey     String?
  result      Json?
  outputFiles Json?
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@map("processing_jobs")
}

model CachedResult {
  id          String   @id @default(cuid())
  fingerprint String   @unique
  result      Json
  createdAt   DateTime @default(now())

  @@map("cached_results")
}
