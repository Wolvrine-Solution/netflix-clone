{
  "name": "netflix-clone",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "db:push": "turbo run db:push --filter=@netflix/db",
    "db:migrate": "turbo run db:migrate --filter=@netflix/db",
    "db:studio": "turbo run db:studio --filter=@netflix/db",
    "db:seed": "turbo run db:seed --filter=@netflix/db",
    "test": "turbo run test",
    "mobile": "pnpm --filter @netflix/mobile dev",
    "mobile:android": "pnpm --filter @netflix/mobile android",
    "mobile:ios": "pnpm --filter @netflix/mobile ios"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "prettier": "^3.3.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "esbuild", "prisma", "unrs-resolver", "react-native-reanimated"],
    "overrides": {
      "@babel/preset-env": "7.25.2",
      "metro": "0.81.5",
      "metro-cache": "0.81.5",
      "metro-config": "0.81.5",
      "metro-resolver": "0.81.5",
      "metro-runtime": "0.81.5",
      "metro-source-map": "0.81.5",
      "metro-transform-worker": "0.81.5"
    }
  }
}
