generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────── AUTH ────────────────────────────────────────

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  emailVerified  DateTime?
  name           String?
  image          String?
  hashedPassword String?
  role           Role           @default(USER)
  isSuspended    Boolean        @default(false)
  mfaEnabled     Boolean        @default(false)
  mfaSecret      String?
  tosAcceptedAt  DateTime?
  privacyAcceptedAt DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  accounts       Account[]
  sessions       Session[]
  profiles       Profile[]
  subscription   Subscription?
  notifications  Notification[]
  reviews        Review[]
  adminLogs      AdminLog[]     @relation("AdminWhoActed")
  refreshTokens  RefreshToken[]
  playbackSessions PlaybackSession[]
  purchases      Purchase[]
  eventEntitlements EventEntitlement[]
  consentRecords ConsentRecord[]
  dataSubjectRequests DataSubjectRequest[]
  downloadLicenses DownloadLicense[]
  qoeEvents      QoEEvent[]
}

enum Role {
  USER
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────── PROFILES ────────────────────────────────────

model Profile {
  id           String         @id @default(cuid())
  name         String
  avatarUrl    String
  isKid        Boolean        @default(false)
  pinHash      String?
  language     String         @default("en")
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  myList       MyListItem[]
  watchHistory WatchHistory[]
  reviews      Review[]

  @@unique([userId, name])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────── SUBSCRIPTIONS ───────────────────────────────

model Subscription {
  id               String    @id @default(cuid())
  userId           String    @unique
  plan             Plan      @default(STANDARD)
  status           SubStatus @default(ACTIVE)
  stripeCustomerId String?   @unique
  stripePriceId    String?
  stripeSubId      String?   @unique
  currentPeriodEnd DateTime?
  cancelAtPeriodEnd Boolean  @default(false)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Plan {
  BASIC
  STANDARD
  PREMIUM
}

enum SubStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

// ─────────────────────────────── CONTENT ─────────────────────────────────────

model Content {
  id             String          @id @default(cuid())
  tmdbId         Int?            @unique
  mediaType      MediaType
  title          String
  description    String          @db.Text
  posterPath     String
  backdropPath   String
  trailerKey     String?
  videoUrl       String?
  releaseDate    String
  rating         Float
  runtime        Int?
  seasons        Int?
  episodes       Int?
  maturityRating String          @default("TV-MA")
  isFeatured     Boolean         @default(false)
  status         ContentStatus   @default(PUBLISHED)
  language       String          @default("en")
  country        String?
  studio         String?
  director       String?
  tagline        String?
  cast           String[]        @default([])
  genres         ContentGenre[]
  contentSeasons Season[]
  videoFiles     VideoFile[]
  myListItems    MyListItem[]
  watchHistory   WatchHistory[]
  rowItems       ContentRow[]
  categories     ContentCategory[]
  reviews        Review[]
  assets         Asset[]
  captions       Caption[]
  trickPlaySprites TrickPlaySprite[]
  licenseWindows LicenseWindow[]
  purchases      Purchase[]
  outboxEvents   OutboxEvent[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

enum MediaType {
  movie
  tv
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ─────────────────────────────── VIDEO FILES ─────────────────────────────────

model VideoFile {
  id        String        @id @default(cuid())
  contentId String?
  episodeId String?
  quality   VideoQuality  @default(AUTO)
  url       String
  size      BigInt?
  duration  Int?
  format    String?
  isDefault Boolean       @default(false)
  content   Content?      @relation(fields: [contentId], references: [id], onDelete: Cascade)
  episode   Episode?      @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())
}

enum VideoQuality {
  AUTO
  Q_4K
  Q_1080P
  Q_720P
  Q_480P
  Q_360P
}

// ─────────────────────────────── TV SEASONS & EPISODES ───────────────────────

model Season {
  id           String    @id @default(cuid())
  contentId    String
  seasonNumber Int
  title        String?
  description  String?   @db.Text
  posterPath   String?
  airDate      String?
  content      Content   @relation(fields: [contentId], references: [id], onDelete: Cascade)
  episodes     Episode[]
  createdAt    DateTime  @default(now())

  @@unique([contentId, seasonNumber])
}

model Episode {
  id            String      @id @default(cuid())
  seasonId      String
  episodeNumber Int
  title         String
  description   String?     @db.Text
  stillPath     String?
  runtime       Int?
  airDate       String?
  videoUrl      String?
  videoFiles    VideoFile[]
  season        Season      @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([seasonId, episodeNumber])
}

// ─────────────────────────────── GENRES & CATEGORIES ─────────────────────────

model Genre {
  id       Int            @id
  name     String         @unique
  contents ContentGenre[]
}

model ContentGenre {
  contentId String
  genreId   Int
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  genre     Genre   @relation(fields: [genreId], references: [id])

  @@id([contentId, genreId])
}

model Category {
  id          String            @id @default(cuid())
  name        String            @unique
  slug        String            @unique
  description String?
  color       String?
  icon        String?
  isActive    Boolean           @default(true)
  order       Int               @default(0)
  contents    ContentCategory[]
  createdAt   DateTime          @default(now())
}

model ContentCategory {
  contentId  String
  categoryId String
  content    Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([contentId, categoryId])
}

// ─────────────────────────────── BROWSE ROWS ─────────────────────────────────

model Row {
  id         String       @id @default(cuid())
  title      String
  query      String
  order      Int
  mediaType  String?
  isActive   Boolean      @default(true)
  contents   ContentRow[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model ContentRow {
  contentId String
  rowId     String
  order     Int
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  row       Row     @relation(fields: [rowId], references: [id], onDelete: Cascade)

  @@id([contentId, rowId])
}

// ─────────────────────────────── USER CONTENT DATA ───────────────────────────

model MyListItem {
  id        String   @id @default(cuid())
  profileId String
  contentId String
  addedAt   DateTime @default(now())
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([profileId, contentId])
}

model WatchHistory {
  id          String   @id @default(cuid())
  profileId   String
  contentId   String
  episodeId   String?
  progress    Float    @default(0)
  watchedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  content     Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([profileId, contentId])
}

model Review {
  id        String   @id @default(cuid())
  profileId String
  contentId String
  userId    String
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([profileId, contentId])
}

// ─────────────────────────────── NOTIFICATIONS ───────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(GENERAL)
  title     String
  message   String           @db.Text
  read      Boolean          @default(false)
  link      String?
  imageUrl  String?
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())
}

enum NotificationType {
  NEW_CONTENT
  SUBSCRIPTION
  SYSTEM
  GENERAL
  PROMO
  ACCOUNT
}

// ─────────────────────────────── ADMIN AUDIT LOG ─────────────────────────────

model AdminLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  resource   String
  resourceId String?
  details    Json?
  ipAddress  String?
  admin      User     @relation("AdminWhoActed", fields: [adminId], references: [id])
  createdAt  DateTime @default(now())
}

// ─────────────────────────────── VOD ASSETS & PLAYBACK ───────────────────────

enum AssetStatus {
  UPLOADED
  TRANSCODING
  PACKAGED
  READY
  FAILED
}

model Asset {
  id          String      @id @default(cuid())
  contentId   String?
  episodeId   String?
  status      AssetStatus @default(UPLOADED)
  sourceKey   String
  manifestUrl String?
  hlsUrl      String?
  dashUrl     String?
  drmKeyId    String?
  error       String?
  content     Content?    @relation(fields: [contentId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([contentId])
  @@index([status])
}

model Caption {
  id        String   @id @default(cuid())
  contentId String?
  episodeId String?
  language  String
  url       String
  content   Content? @relation(fields: [contentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([contentId])
}

model TrickPlaySprite {
  id          String  @id @default(cuid())
  contentId   String
  url         String
  intervalSec Int     @default(10)
  content     Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model LicenseWindow {
  id          String   @id @default(cuid())
  contentId   String
  territories String[] @default([])
  startsAt    DateTime
  endsAt      DateTime
  content     Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([contentId, endsAt])
}

model QoEEvent {
  id        String   @id @default(cuid())
  userId    String?
  contentId String
  eventType String
  metadata  Json?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([contentId, createdAt])
}

// ─────────────────────────────── LIVE STREAMING ──────────────────────────────

enum LiveEventStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

model LiveChannel {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String?     @db.Text
  isActive    Boolean     @default(true)
  events      LiveEvent[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model LiveEvent {
  id                String          @id @default(cuid())
  channelId         String
  title             String
  description       String?         @db.Text
  status            LiveEventStatus @default(SCHEDULED)
  scheduledStart    DateTime
  scheduledEnd      DateTime?
  ingestUrl         String?
  playbackUrl       String?
  dvrWindowSec      Int             @default(7200)
  slatePreUrl       String?
  slatePostUrl      String?
  geoRestricted     String[]        @default([])
  blackoutRegions   String[]        @default([])
  archivedContentId String?
  channel           LiveChannel     @relation(fields: [channelId], references: [id], onDelete: Cascade)
  entitlements      EventEntitlement[]
  purchases         Purchase[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([channelId, scheduledStart])
  @@index([status])
}

model EventEntitlement {
  id        String    @id @default(cuid())
  eventId   String
  userId    String
  event     LiveEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([eventId, userId])
}

// ─────────────────────────────── BILLING & ENTITLEMENTS ──────────────────────

model StripeWebhookEvent {
  id          String   @id @default(cuid())
  stripeEventId String @unique
  processedAt DateTime @default(now())
}

enum PurchaseType {
  PPV
  TVOD
}

model Purchase {
  id                    String       @id @default(cuid())
  userId                String
  contentId             String?
  eventId               String?
  type                  PurchaseType
  amountCents           Int
  stripePaymentIntentId String?      @unique
  user                  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  content               Content?     @relation(fields: [contentId], references: [id], onDelete: SetNull)
  event                 LiveEvent?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  createdAt             DateTime     @default(now())

  @@index([userId])
}

model PlaybackSession {
  id            String   @id @default(cuid())
  userId        String
  profileId     String?
  deviceId      String
  qualityCap    String?
  lastHeartbeat DateTime @default(now())
  expiresAt     DateTime
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

// ─────────────────────────────── SEARCH & EVENTS ─────────────────────────────

model OutboxEvent {
  id            String    @id @default(cuid())
  aggregateType String
  aggregateId   String
  eventType     String
  payload       Json
  processedAt   DateTime?
  contentId     String?
  content       Content?  @relation(fields: [contentId], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())

  @@index([processedAt, createdAt])
}

// ─────────────────────────────── COMPLIANCE ──────────────────────────────────

enum DmcaStatus {
  OPEN
  RESOLVED
  REJECTED
}

model DmcaTakedown {
  id            String     @id @default(cuid())
  reporterEmail String
  contentId     String?
  details       String     @db.Text
  status        DmcaStatus @default(OPEN)
  createdAt     DateTime   @default(now())
  resolvedAt    DateTime?
}

enum DsarType {
  EXPORT
  DELETE
}

enum DsarStatus {
  PENDING
  COMPLETED
  FAILED
}

model ConsentRecord {
  id          String   @id @default(cuid())
  userId      String
  consentType String
  granted     Boolean
  ipAddress   String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([userId, consentType])
}

model DataSubjectRequest {
  id          String     @id @default(cuid())
  userId      String
  type        DsarType
  status      DsarStatus @default(PENDING)
  completedAt DateTime?
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())

  @@index([userId, status])
}

model DownloadLicense {
  id         String   @id @default(cuid())
  userId     String
  contentId  String
  licenseUrl String
  expiresAt  DateTime
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([userId, expiresAt])
}
