generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────── AUTH ────────────────────────────────────────

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  emailVerified  DateTime?
  name           String?
  image          String?
  hashedPassword String?
  role           Role           @default(USER)
  isSuspended    Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  accounts       Account[]
  sessions       Session[]
  profiles       Profile[]
  subscription   Subscription?
  notifications  Notification[]
  reviews        Review[]
  adminLogs      AdminLog[]     @relation("AdminWhoActed")
}

enum Role {
  USER
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────── PROFILES ────────────────────────────────────

model Profile {
  id           String         @id @default(cuid())
  name         String
  avatarUrl    String
  isKid        Boolean        @default(false)
  language     String         @default("en")
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  myList       MyListItem[]
  watchHistory WatchHistory[]
  reviews      Review[]

  @@unique([userId, name])
}

// ─────────────────────────────── SUBSCRIPTIONS ───────────────────────────────

model Subscription {
  id               String    @id @default(cuid())
  userId           String    @unique
  plan             Plan      @default(STANDARD)
  status           SubStatus @default(ACTIVE)
  stripeCustomerId String?   @unique
  stripePriceId    String?
  stripeSubId      String?   @unique
  currentPeriodEnd DateTime?
  cancelAtPeriodEnd Boolean  @default(false)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Plan {
  BASIC
  STANDARD
  PREMIUM
}

enum SubStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

// ─────────────────────────────── CONTENT ─────────────────────────────────────

model Content {
  id             String          @id @default(cuid())
  tmdbId         Int?            @unique
  mediaType      MediaType
  title          String
  description    String          @db.Text
  posterPath     String
  backdropPath   String
  trailerKey     String?
  videoUrl       String?
  releaseDate    String
  rating         Float
  runtime        Int?
  seasons        Int?
  episodes       Int?
  maturityRating String          @default("TV-MA")
  isFeatured     Boolean         @default(false)
  status         ContentStatus   @default(PUBLISHED)
  language       String          @default("en")
  country        String?
  studio         String?
  director       String?
  tagline        String?
  cast           String[]        @default([])
  genres         ContentGenre[]
  contentSeasons Season[]
  videoFiles     VideoFile[]
  myListItems    MyListItem[]
  watchHistory   WatchHistory[]
  rowItems       ContentRow[]
  reviews        Review[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

enum MediaType {
  movie
  tv
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ─────────────────────────────── VIDEO FILES ─────────────────────────────────

model VideoFile {
  id        String        @id @default(cuid())
  contentId String?
  episodeId String?
  quality   VideoQuality  @default(AUTO)
  url       String
  size      BigInt?
  duration  Int?
  format    String?
  isDefault Boolean       @default(false)
  content   Content?      @relation(fields: [contentId], references: [id], onDelete: Cascade)
  episode   Episode?      @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())
}

enum VideoQuality {
  AUTO
  Q_4K
  Q_1080P
  Q_720P
  Q_480P
  Q_360P
}

// ─────────────────────────────── TV SEASONS & EPISODES ───────────────────────

model Season {
  id           String    @id @default(cuid())
  contentId    String
  seasonNumber Int
  title        String?
  description  String?   @db.Text
  posterPath   String?
  airDate      String?
  content      Content   @relation(fields: [contentId], references: [id], onDelete: Cascade)
  episodes     Episode[]
  createdAt    DateTime  @default(now())

  @@unique([contentId, seasonNumber])
}

model Episode {
  id            String      @id @default(cuid())
  seasonId      String
  episodeNumber Int
  title         String
  description   String?     @db.Text
  stillPath     String?
  runtime       Int?
  airDate       String?
  videoUrl      String?
  videoFiles    VideoFile[]
  season        Season      @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([seasonId, episodeNumber])
}

// ─────────────────────────────── GENRES & CATEGORIES ─────────────────────────

model Genre {
  id       Int            @id
  name     String         @unique
  contents ContentGenre[]
}

model ContentGenre {
  contentId String
  genreId   Int
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  genre     Genre   @relation(fields: [genreId], references: [id])

  @@id([contentId, genreId])
}

model Category {
  id          String            @id @default(cuid())
  name        String            @unique
  slug        String            @unique
  description String?
  color       String?
  icon        String?
  isActive    Boolean           @default(true)
  order       Int               @default(0)
  contents    ContentCategory[]
  createdAt   DateTime          @default(now())
}

model ContentCategory {
  contentId  String
  categoryId String
  content    Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([contentId, categoryId])
}

// ─────────────────────────────── BROWSE ROWS ─────────────────────────────────

model Row {
  id         String       @id @default(cuid())
  title      String
  query      String
  order      Int
  mediaType  String?
  isActive   Boolean      @default(true)
  contents   ContentRow[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model ContentRow {
  contentId String
  rowId     String
  order     Int
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  row       Row     @relation(fields: [rowId], references: [id], onDelete: Cascade)

  @@id([contentId, rowId])
}

// ─────────────────────────────── USER CONTENT DATA ───────────────────────────

model MyListItem {
  id        String   @id @default(cuid())
  profileId String
  contentId String
  addedAt   DateTime @default(now())
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([profileId, contentId])
}

model WatchHistory {
  id          String   @id @default(cuid())
  profileId   String
  contentId   String
  episodeId   String?
  progress    Float    @default(0)
  watchedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  content     Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([profileId, contentId])
}

model Review {
  id        String   @id @default(cuid())
  profileId String
  contentId String
  userId    String
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([profileId, contentId])
}

// ─────────────────────────────── NOTIFICATIONS ───────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(GENERAL)
  title     String
  message   String           @db.Text
  read      Boolean          @default(false)
  link      String?
  imageUrl  String?
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())
}

enum NotificationType {
  NEW_CONTENT
  SUBSCRIPTION
  SYSTEM
  GENERAL
  PROMO
  ACCOUNT
}

// ─────────────────────────────── ADMIN AUDIT LOG ─────────────────────────────

model AdminLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  resource   String
  resourceId String?
  details    Json?
  ipAddress  String?
  admin      User     @relation("AdminWhoActed", fields: [adminId], references: [id])
  createdAt  DateTime @default(now())
}
