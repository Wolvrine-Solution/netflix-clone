# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/netflixclone"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# CORS (comma-separated allowlist)
CORS_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:8081,http://localhost:19006"

# OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# TMDB
TMDB_API_KEY=""
TMDB_BASE_URL="https://api.themoviedb.org/3"
TMDB_IMAGE_BASE_URL="https://image.tmdb.org/t/p"

# Internal API
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Redis
REDIS_URL="redis://localhost:6379"

# Object storage (MinIO local / S3 prod)
S3_ENDPOINT="http://localhost:9000"
S3_BUCKET="netflix-vod"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_REGION="us-east-1"
CDN_SIGNING_SECRET=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_BASIC=""
STRIPE_PRICE_STANDARD=""
STRIPE_PRICE_PREMIUM=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Observability
SENTRY_DSN=""
OTEL_EXPORTER_OTLP_ENDPOINT=""

# Auth token TTL
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS="30"
JSON_BODY_LIMIT="1mb"
